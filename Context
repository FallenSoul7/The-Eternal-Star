const toggleSubPanel = (panel: 'toolbox' | 'assets' | 'settings') => {
if (activeSubPanel === panel) {
setActiveSubPanel('none')
if (panel === 'toolbox' && panelsVisibility.toolbox) {
togglePanel('toolbox')
}
} else {
setActiveSubPanel(panel)
if (panel === 'toolbox' && !panelsVisibility.toolbox) {
togglePanel('toolbox')
}
}
